{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "github>druidfi/renovate-config:global"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "enabled": true,
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^misc/docker-bake\\.hcl$/"
      ],
      "matchStrings": [
        "variable SIMPLESAMLPHP_VERSION \\{\\s+default = \"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "simplesamlphp/simplesamlphp",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver"
    }
  ]
}
