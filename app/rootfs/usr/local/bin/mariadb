#!/bin/bash
# --defaults-file must be the first argument if present, so extract and reorder
ARGS=()
DEFAULTS_FILE_ARG=""

for arg in "$@"; do
  if [[ "$arg" == --defaults-file=* ]]; then
    DEFAULTS_FILE_ARG="$arg"
  else
    ARGS+=("$arg")
  fi
done

if [[ -n "$DEFAULTS_FILE_ARG" ]]; then
  exec /usr/bin/mariadb "$DEFAULTS_FILE_ARG" --ssl-verify-server-cert=0 "${ARGS[@]}"
else
  exec /usr/bin/mariadb --ssl-verify-server-cert=0 "${ARGS[@]}"
fi
