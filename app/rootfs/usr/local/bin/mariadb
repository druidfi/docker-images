#!/bin/sh
# Drush passes --defaults-file which replaces all cnf files including
# /etc/my.cnf.d/mariadb-client.cnf. Inject disable-ssl-verify-server-cert
# into the temp file Drush created so it is still picked up.
for arg in "$@"; do
  case "$arg" in
    --defaults-file=*)
      printf '\ndisable-ssl-verify-server-cert\n' >> "${arg#--defaults-file=}"
      break
      ;;
  esac
done
exec /usr/bin/mariadb "$@"
